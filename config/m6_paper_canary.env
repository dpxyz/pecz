# Hyperliquid ENV Configuration
## Paper/Mock Only - No Live Keys

# === SAFETY GATES (HARD BLOCKS) ===
export ENABLE_EXECUTION_LIVE=false
export MAINNET_TRADING_ALLOWED=false
export PAPER_TRADING_ALLOWED=true
export MOCK_EXECUTION_ALLOWED=true

# === HYPERLIQUID MODE ===
# Allowed: mock | paper
# BLOCKED: testnet | mainnet (until Phase 9 + manual approval)
export HL_MODE=paper

# === MOCK/PAPER CONFIG ===
# Wallet address for paper tracking (NOT a real key!)
export HL_MOCK_WALLET="0xMOCK000000000000000000000000000000000000"

# RPC for price data only (read-only)
export HL_RPC_ENDPOINT="https://api.hyperliquid.xyz"
export HL_WS_ENDPOINT="wss://api.hyperliquid.xyz/ws"

# === PAPER CANARY ===
export PAPER_CANARY_MAX_TRADES=1
export PAPER_CANARY_ALLOWED_SYMBOLS='["BTC-USD"]'
export PAPER_CANARY_MAX_NOTIONAL=11
export PAPER_CANARY_PAUSE_AFTER_FILL=true

# === RISK PARAMETERS ===
export PAPER_CANARY_SL_PCT=0.88
export PAPER_CANARY_TP_PCT=1.76

# === OBSERVABILITY ===
export DISCORD_WEBHOOK=""
export ALERT_ON_PAPER_FILL=true

# === DATABASE ===
export DB_PATH="./runtime/app.db"

# === LOGGING ===
export LOG_LEVEL="info"
export LOG_STRUCTURED=true

# === SAFETY FLAGS ===
export SAFETY_BLOCK_ON_MISMATCH=true
export SAFETY_PAUSE_ON_REJECT_RATE=10
export SAFETY_MAX_WATCHDOG_AGE_MS=600000

# === DANGER ZONE - DO NOT ENABLE ===
# These are BLOCKED until Phase 9 + manual approval:
# HL_API_PRIVATE_KEY=<NEVER SET>
# HL_VAULT_ADDRESS=<NEVER SET>
# ENABLE_EXECUTION_LIVE=true  # NEVER!
# MAINNET_TRADING_ALLOWED=true  # NEVER!
