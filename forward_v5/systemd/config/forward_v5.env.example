# OpenClaw Forward v5 - Environment Configuration
# Location: /etc/openclaw/forward_v5.env (optional)
#
# Diese Datei wird vom systemd service geladen (wenn vorhanden)
# und überschreibt/ergänzt die in der Service-Unit definierten Werte

# =====================================================
# CORE SETTINGS (Required)
# =====================================================

# Event Store Pfad (relativ zu WorkingDirectory)
EVENT_STORE_PATH=./runtime/event_store.db

# Node.js Environment
NODE_ENV=production

# Forward Version
FORWARD_VERSION=5.1.0

# =====================================================
# RUNTIME VALIDATION SETTINGS
# =====================================================

# Mode: paper (kein Live-Trading)
HL_MODE=paper
ENABLE_EXECUTION_LIVE=false

# Health Check Interval (Sekunden)
HEALTH_CHECK_INTERVAL=300

# Heartbeat Interval (Sekunden)
HEARTBEAT_INTERVAL=60

# Log Level
LOG_LEVEL=info

# =====================================================
# SAFETY SETTINGS
# =====================================================

# Circuit Breaker automatisch aktivieren
CIRCUIT_BREAKER_AUTO_RESET=false

# Max Memory Threshold (%)
MEMORY_THRESHOLD_CRITICAL=90
MEMORY_THRESHOLD_WARN=80

# =====================================================
# OPTIONAL: API Credentials (nur für Paper Mode)
# =====================================================
# ACHTUNG: Diese sollten besser in /etc/openclaw/secrets/ liegen
#
# HL_API_KEY=
# HL_API_SECRET=

# =====================================================
# DEBUGGING (nur für Entwicklung)
# =====================================================
# NODE_DEBUG=net,http
# DEBUG=*
