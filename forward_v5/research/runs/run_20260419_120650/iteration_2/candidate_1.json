{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Crypto_Trend_Momentum_Follower",
    "type": "trend_following",
    "hypothesis": "Sustained trends in BTC, ETH, and SOL are often confirmed by EMA crossovers and validated by RSI momentum during 1h intervals.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      },
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) > EMA(50) AND RSI(14) > 55",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": 0.5,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "trend",
        "params": {
          "min_slope": 0.01
        }
      }
    ]
  }
}