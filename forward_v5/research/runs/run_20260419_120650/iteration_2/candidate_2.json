{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Mean_Reversion_Bollinger_ZScore",
    "type": "mean_reversion",
    "hypothesis": "Price extremes relative to the 20-period mean (Z-Score > 2) tend to revert in highly liquid crypto assets on the 1h timeframe.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2.0
        }
      },
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      }
    ],
    "entry": {
      "condition": "Close < BB_Lower AND ZSCORE(20) < -2.0",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 1.2,
      "stop_loss_pct": 1.0,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 2.5
        }
      }
    ]
  }
}