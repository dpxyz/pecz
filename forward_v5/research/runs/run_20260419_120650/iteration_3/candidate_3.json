{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Volatility_Breakout_Hybrid",
    "type": "breakout",
    "hypothesis": "Einstieg bei Ausbruch aus Bollinger-Band-Engp\u00e4ssen best\u00e4tigt durch Volumenanstieg.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "close > BB_upper(20, 2) AND volume > SMA(volume, 20)",
      "max_per_day": 1
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 2.0,
      "trailing_stop_pct": 0.5,
      "max_hold_bars": 72
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "trend",
        "params": {
          "min_sma_period": 50
        }
      }
    ]
  }
}