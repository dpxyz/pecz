{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Trend_Momentum_Crossover",
    "type": "trend_following",
    "hypothesis": "Kombination aus langfristigem Trend (SMA) und kurzfristigem Momentum (EMA) zur Erfassung von Trendfortsetzungen in Krypto-Assets.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "SMA",
        "params": {
          "period": 200
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      }
    ],
    "entry": {
      "condition": "close > SMA(200) AND close > EMA(20) AND close[1] <= EMA(20)[1]",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 5.0,
      "stop_loss_pct": 2.5,
      "trailing_stop_pct": 1.0,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volume",
        "params": {
          "min_volume_ma_ratio": 1.2
        }
      }
    ]
  }
}