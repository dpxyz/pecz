{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Mean_Reversion_ZScore",
    "type": "mean_reversion",
    "hypothesis": "Ausnutzung von kurzfristigen \u00dcbertreibungen (Mean Reversion) basierend auf statistischen Abweichungen vom Durchschnitt.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      },
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "ZSCORE(20) < -2.0 AND RSI(14) < 30",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 3.0
        }
      }
    ]
  }
}