{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Crypto_Trend_Follower_EMA",
    "type": "trend_following",
    "hypothesis": "Long-term momentum on 1h timeframe persists across major assets during bullish phases.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) crosses above EMA(50) and close > EMA(50)",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 4.0,
      "stop_loss_pct": 2.0,
      "trailing_stop_pct": 1.0,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volume",
        "params": {
          "min_volume_increase_pct": 10
        }
      }
    ]
  }
}