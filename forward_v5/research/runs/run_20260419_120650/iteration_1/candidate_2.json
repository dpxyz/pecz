{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Mean_Reversion_RSI_ZScore",
    "type": "mean_reversion",
    "hypothesis": "Overextended price moves in 1h timeframe often revert to the mean when RSI is oversold and Z-Score indicates a statistical outlier.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      },
      {
        "name": "SMA",
        "params": {
          "period": 200
        }
      }
    ],
    "entry": {
      "condition": "RSI < 30 AND ZSCORE < -2.0 AND close > SMA(200)",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 2.0,
      "stop_loss_pct": 2.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "trend",
        "params": {
          "min_sma_period": 200
        }
      }
    ]
  }
}