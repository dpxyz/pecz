{
  "dsl_version": "0.1",
  "strategy": {
    "name": "RSI_EMA_Trend_Filter_V1",
    "type": "hybrid",
    "hypothesis": "Buying oversold dips (RSI < 30) only when the long-term trend is bullish (close > EMA 50) reduces consecutive losses and increases profit factor.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      }
    ],
    "entry": {
      "condition": "rsi_14 < 30 AND close > ema_50",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 72
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}