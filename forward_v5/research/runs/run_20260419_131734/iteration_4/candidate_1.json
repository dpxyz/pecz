{
  "dsl_version": "0.1",
  "strategy": {
    "name": "MeanReversion_ZScore_Volatility",
    "type": "mean_reversion",
    "hypothesis": "Extreme price deviations measured by ZScore combined with ATR volatility spikes often lead to sharp reversals on 1h timeframes.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "zscore_20 < -2.0 AND atr_14 > close * 0.01",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.5,
      "stop_loss_pct": 2.0,
      "trailing_stop_pct": null,
      "max_hold_bars": 36
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}