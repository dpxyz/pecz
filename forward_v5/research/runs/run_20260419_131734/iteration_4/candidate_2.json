{
  "dsl_version": "0.1",
  "strategy": {
    "name": "BB_RSI_Bounce_Aggressive",
    "type": "mean_reversion",
    "hypothesis": "Combining Bollinger Band lower boundary breach with an oversold RSI increases the probability of a mean-reversion bounce.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2.0
        }
      }
    ],
    "entry": {
      "condition": "close < bb_lower_20 AND rsi_14 < 35",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}