{
  "dsl_version": "0.1",
  "strategy": {
    "name": "ZScore_Volatility_Reversion",
    "type": "mean_reversion",
    "hypothesis": "Uses ZScore for statistical deviation and ATR to ensure sufficient volatility for a profitable bounce, improving the profit factor over standard ZScore.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "zscore_20 < -2.0 AND atr_14 > (close * 0.01)",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 2.0,
      "trailing_stop_pct": null,
      "max_hold_bars": 48
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}