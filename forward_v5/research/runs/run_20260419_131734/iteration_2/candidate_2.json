{
  "dsl_version": "0.1",
  "strategy": {
    "name": "SOL_Volatility_RSI_Bounce",
    "type": "mean_reversion",
    "hypothesis": "SOL exhibits higher volatility; combining a low RSI with a BB lower band breach identifies high-probability exhaustion points for a quick bounce.",
    "assets": [
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2.0
        }
      }
    ],
    "entry": {
      "condition": "rsi_14 < 35 AND close < bb_lower_20",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 2.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 48
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}