{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Hybrid_EMA_ZScore_Reversion",
    "type": "hybrid",
    "hypothesis": "Using a long-term EMA as a trend filter prevents catching 'falling knives' while ZScore identifies the precise mean-reversion entry point.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      },
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      }
    ],
    "entry": {
      "condition": "close > ema_50 AND zscore_20 < -1.5",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 2.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}