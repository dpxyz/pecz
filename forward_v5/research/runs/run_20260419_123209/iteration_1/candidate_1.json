{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Crypto_Trend_Follower_EMA",
    "type": "trend_following",
    "hypothesis": "Strong trends in BTC, ETH, and SOL on the 1h timeframe can be captured by combining a fast and slow EMA crossover with a volume filter to ensure liquidity.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      },
      {
        "name": "SMA",
        "params": {
          "period": 200
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) > EMA(50) AND close > SMA(200) AND volume > SMA(volume, 20)",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": 0.5,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volume",
        "params": {
          "min_volume_multiplier": 1.2
        }
      }
    ]
  }
}