{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Mean_Reversion_ZScore_Refined",
    "type": "mean_reversion",
    "hypothesis": "Price extremes relative to the mean (Z-Score) in high-liquidity crypto assets tend to revert when coupled with volatility filters to avoid catching falling knives.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "ZSCORE < -2.0 AND ATR < (SMA(ATR, 100) * 1.5)",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 2.5,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": 0.5,
      "max_hold_bars": 36
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 2.0
        }
      }
    ]
  }
}