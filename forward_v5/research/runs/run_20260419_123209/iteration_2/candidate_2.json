{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Hybrid_Breakout_RSI",
    "type": "hybrid",
    "hypothesis": "Combining volatility breakouts with RSI confirmation to ensure entries occur during strong momentum, improving the Return/Drawdown ratio.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std": 2
        }
      },
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "close > BB_upper AND RSI > 60",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.8,
      "trailing_stop_pct": 0.8,
      "max_hold_bars": 72
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "trend",
        "params": {
          "min_sma_period": 50
        }
      }
    ]
  }
}