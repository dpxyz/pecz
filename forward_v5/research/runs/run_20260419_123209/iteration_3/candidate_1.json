{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Trend_Following_EMA_ZScore",
    "type": "trend_following",
    "hypothesis": "Kombination aus langfristigem Trendfilter (EMA) und kurzfristigem Momentum-Ausbruch (ZScore) zur Reduktion von False-Signals.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 200
        }
      },
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      }
    ],
    "entry": {
      "condition": "close > EMA(200) AND ZSCORE(20) > 1.5",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": 0.5,
      "max_hold_bars": 72
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 2.5
        }
      }
    ]
  }
}