{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Trend_Following_EMA_Crossover",
    "type": "trend_following",
    "hypothesis": "Capturing medium-term momentum on BTC and ETH using EMA alignment to reduce noise and avoid whipsaws.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) crosses above EMA(50) and close > EMA(50)",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 4.0,
      "stop_loss_pct": 2.5,
      "trailing_stop_pct": 1.5,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volume",
        "params": {
          "min_volume_multiplier": 1.2
        }
      }
    ]
  }
}