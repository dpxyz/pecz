{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Trend_Follower_EMA_Cross",
    "type": "trend_following",
    "hypothesis": "Momentum-Trades auf 1h-Basis durch EMA-Crossover in Verbindung mit RSI-Best\u00e4tigung zur Vermeidung von \u00fcberkauften Zonen.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      },
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) crosses above EMA(50) AND RSI < 70",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": 0.5,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volume",
        "params": {
          "min_volume_multiplier": 1.2
        }
      }
    ]
  }
}