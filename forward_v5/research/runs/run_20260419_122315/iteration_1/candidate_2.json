{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Mean_Reversion_ZScore_BB",
    "type": "mean_reversion",
    "hypothesis": "Statistische Ausrei\u00dfer au\u00dferhalb der Bollinger B\u00e4nder in Kombination mit einem extremen Z-Score signalisieren kurzfristige \u00dcbertreibungen.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2
        }
      },
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      }
    ],
    "entry": {
      "condition": "Close < BB_lower AND ZSCORE < -2.0",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 1.2,
      "stop_loss_pct": 2.0,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 3.0
        }
      }
    ]
  }
}