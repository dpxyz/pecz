{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Crypto_Trend_Momentum_Hybrid",
    "type": "hybrid",
    "hypothesis": "Kombination aus langfristigem Trendfilter (SMA) und kurzfristigem Momentum (RSI) zur Identifikation von Trendfortsetzungen in einem Bullenmarkt.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "SMA",
        "params": {
          "period": 200
        }
      },
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "close > SMA(200) AND RSI(14) crosses above 50",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": 0.5,
      "max_hold_bars": 72
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volume",
        "params": {
          "min_volume_multiplier": 1.2
        }
      }
    ]
  }
}