{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Crypto_Trend_Follower_EMA",
    "type": "trend_following",
    "hypothesis": "Momentum-Ausbr\u00fcche \u00fcber den 200h EMA signalisieren einen starken institutionellen Trend, der durch kurzfristige EMA-Crosses best\u00e4tigt wird.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 200
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      }
    ],
    "entry": {
      "condition": "Close > EMA(200) AND EMA(20) crosses above EMA(50)",
      "max_per_day": 1
    },
    "exit": {
      "take_profit_pct": 5.0,
      "stop_loss_pct": 2.5,
      "trailing_stop_pct": 1.0,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volume",
        "params": {
          "min_volume_multiplier": 1.2
        }
      }
    ]
  }
}