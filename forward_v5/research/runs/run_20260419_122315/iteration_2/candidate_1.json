{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Trend_Follower_EMA_Cross",
    "type": "trend_following",
    "hypothesis": "Momentum-Best\u00e4tigung durch EMA-Crossover auf 1h-Basis bei hoher Volatilit\u00e4t in Krypto-Assets",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) crosses above EMA(50) and close > EMA(50)",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": 0.5,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "trend",
        "params": {
          "indicator": "SMA",
          "period": 200,
          "condition": "above"
        }
      }
    ]
  }
}