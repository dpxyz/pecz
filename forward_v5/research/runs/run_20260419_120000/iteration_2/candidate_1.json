{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Trend_Momentum_Crossover",
    "type": "trend_following",
    "hypothesis": "Combination of fast and slow EMAs combined with RSI filter captures strong momentum phases in high-beta crypto assets.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      },
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) crosses above EMA(50) AND RSI(14) > 55",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 4.0,
      "stop_loss_pct": 2.5,
      "trailing_stop_pct": 1.0,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volume",
        "params": {
          "min_volume_multiplier": 1.2
        }
      }
    ]
  }
}