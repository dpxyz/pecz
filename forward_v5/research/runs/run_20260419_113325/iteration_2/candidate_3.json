{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Hybrid_Breakout_Momentum",
    "type": "hybrid",
    "hypothesis": "Kombination aus Preis-Breakout und RSI-Momentum zur Identifikation starker Trends mit geringerem Drawdown.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "SMA",
        "params": {
          "period": 100
        }
      },
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "close > SMA(100) AND RSI > 60 AND close > high[1]",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": 0.8,
      "max_hold_bars": 48
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 0.7
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "min_atr_multiplier": 0.5
        }
      }
    ]
  }
}