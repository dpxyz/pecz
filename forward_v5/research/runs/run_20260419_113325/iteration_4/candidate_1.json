{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Trend_Following_EMA_Cross_Optimized",
    "type": "trend_following",
    "hypothesis": "Durch die Verk\u00fcrzung der EMA-Perioden und engere Stop-Loss-Limits wird die Trade-Frequenz erh\u00f6ht und der maximale Drawdown reduziert, um die G2-Risk-Gates zu erf\u00fcllen.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) crosses above EMA(50)",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.5,
      "stop_loss_pct": 1.2,
      "trailing_stop_pct": 0.5,
      "max_hold_bars": 72
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 0.8
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 1.5
        }
      }
    ]
  }
}