{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Trend_Following_EMA_Cross_Refined",
    "type": "trend_following",
    "hypothesis": "Verbesserung der Trade-Frequenz durch leicht k\u00fcrzere EMAs und Reduktion des Drawdowns durch strikteres Risk-Management und ATR-basierte Filterung.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) crosses above EMA(50) AND close > EMA(50)",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": 0.5,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 0.75
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 1.5
        }
      },
      {
        "type": "trend",
        "params": {
          "min_slope": 0.01
        }
      }
    ]
  }
}