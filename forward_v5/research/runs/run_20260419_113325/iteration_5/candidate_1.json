{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Trend_Following_EMA_Cross_Robust",
    "type": "trend_following",
    "hypothesis": "Optimized EMA cross with tighter risk management and higher trade frequency to reduce drawdown and meet profitability gates.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) crosses above EMA(50) and price is above EMA(50)",
      "max_per_day": 5
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": 1.0,
      "max_hold_bars": 72
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 0.75
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 2.5
        }
      }
    ]
  }
}