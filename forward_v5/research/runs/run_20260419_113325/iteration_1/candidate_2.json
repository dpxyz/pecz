{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Mean_Reversion_RSI_BB",
    "type": "mean_reversion",
    "hypothesis": "\u00dcberverkaufte Bedingungen am unteren Bollinger Band in einem Aufw\u00e4rtstrend bieten hohe Probability f\u00fcr kurzfristige Erholungen.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2.0
        }
      },
      {
        "name": "SMA",
        "params": {
          "period": 200
        }
      }
    ],
    "entry": {
      "condition": "close < BB_lower AND RSI < 30 AND close > SMA(200)",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 1.5,
      "stop_loss_pct": 1.0,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 2.5
        }
      }
    ]
  }
}