{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Trend_Following_EMA_Cross",
    "type": "trend_following",
    "hypothesis": "Momentum-Aufbau in Krypto-Assets wird durch das Kreuzen eines kurzfristigen EMA \u00fcber einen langfristigen EMA best\u00e4tigt.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) crosses above EMA(50) AND close > EMA(50)",
      "max_per_day": 1
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": 0.5,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volume",
        "params": {
          "min_volume_multiplier": 1.2
        }
      }
    ]
  }
}