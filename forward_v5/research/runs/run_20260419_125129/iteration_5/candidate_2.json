{
  "dsl_version": "0.1",
  "strategy": {
    "name": "ZScore_EMA_Filter_Reversion",
    "type": "mean_reversion",
    "hypothesis": "Using ZScore for statistical deviation while ensuring the long-term trend is positive via EMA filter to improve Profit Factor.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ZSCORE",
        "params": {
          "period": 50
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 200
        }
      }
    ],
    "entry": {
      "condition": "zscore_50 < -2.0 AND close > ema_200",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 48
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}