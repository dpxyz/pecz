{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Volatility_Squeeze_Breakout",
    "type": "breakout",
    "hypothesis": "Entering trades when RSI indicates momentum and price breaks above the BB upper band after a period of low volatility.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2.0
        }
      }
    ],
    "entry": {
      "condition": "rsi_14 > 60 AND close > bb_upper_20",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 2.0,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}