{
  "dsl_version": "0.1",
  "strategy": {
    "name": "RSI_BB_MeanReversion_1h",
    "type": "mean_reversion",
    "hypothesis": "Extreme oversold conditions combined with a Bollinger Band lower breach on 1h timeframe indicate high probability of short-term bounce.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2.0
        }
      }
    ],
    "entry": {
      "condition": "rsi_14 < 30 AND close < bb_lower_20",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.5,
      "stop_loss_pct": 2.0,
      "trailing_stop_pct": null,
      "max_hold_bars": 48
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}