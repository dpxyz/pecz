{
  "dsl_version": "0.1",
  "strategy": {
    "name": "ZScore_Volatility_Reversion",
    "type": "mean_reversion",
    "hypothesis": "Identifies extreme price deviations via Z-Score combined with ATR volatility spikes to enter trades at local bottoms during high-volatility regimes.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ZSCORE",
        "params": {
          "period": 50
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "zscore_50 < -2.0 AND atr_14 > close * 0.01",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.8,
      "trailing_stop_pct": null,
      "max_hold_bars": 48
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}