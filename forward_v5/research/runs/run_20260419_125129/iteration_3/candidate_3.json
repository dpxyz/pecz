{
  "dsl_version": "0.1",
  "strategy": {
    "name": "EMA_RSI_TrendFilter_Reversion",
    "type": "hybrid",
    "hypothesis": "Uses a long-term EMA to ensure the macro trend is bullish while using RSI for precise mean-reversion entries on short-term dips.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 200
        }
      }
    ],
    "entry": {
      "condition": "rsi_14 < 30 AND close > ema_200",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.2,
      "stop_loss_pct": 2.0,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}