{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Volatility_Squeeze_Breakout",
    "type": "breakout",
    "hypothesis": "Using ATR to identify low volatility regimes and entering when price breaks out of a tight range, targeting rapid expansion.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      },
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2.0
        }
      }
    ],
    "entry": {
      "condition": "close > bb_upper_20 AND atr_14 > (close * 0.01)",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.0,
      "stop_loss_pct": 1.8,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}