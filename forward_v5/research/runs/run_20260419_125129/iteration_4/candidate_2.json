{
  "dsl_version": "0.1",
  "strategy": {
    "name": "RSI_EMA_Trend_Filter_Reversion",
    "type": "hybrid",
    "hypothesis": "Buying RSI oversold conditions only when the long-term trend (EMA 200) is bullish to increase the profit factor and reduce consecutive losses.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 200
        }
      }
    ],
    "entry": {
      "condition": "rsi_14 < 35 AND close > ema_200",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 48
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}