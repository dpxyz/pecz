{
  "dsl_version": "0.1",
  "strategy": {
    "name": "VWAP_RSI_MeanReversion",
    "type": "hybrid",
    "hypothesis": "Prices significantly below VWAP with an RSI dip suggest an institutional value area, creating a high-probability mean reversion trade back toward the VWAP.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "VWAP",
        "params": {
          "period": 20
        }
      },
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 100
        }
      }
    ],
    "entry": {
      "condition": "close < vwap_20 AND rsi_14 < 30 AND close > ema_100",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.2,
      "stop_loss_pct": 1.8,
      "trailing_stop_pct": null,
      "max_hold_bars": 48
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}