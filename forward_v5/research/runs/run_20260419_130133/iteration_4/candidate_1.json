{
  "dsl_version": "0.1",
  "strategy": {
    "name": "ZScore_Volatility_Reversion",
    "type": "mean_reversion",
    "hypothesis": "Extreme price deviations from the mean (ZScore < -2.0) combined with high volatility (ATR) indicate an exhausted sell-off and high probability of a sharp bounce on 1h timeframe.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      }
    ],
    "entry": {
      "condition": "zscore_20 < -2.0 AND close > ema_50",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.5,
      "stop_loss_pct": 2.0,
      "trailing_stop_pct": null,
      "max_hold_bars": 36
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}