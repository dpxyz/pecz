{
  "dsl_version": "0.1",
  "strategy": {
    "name": "ZScore_BB_Reversion_Optimized",
    "type": "mean_reversion",
    "hypothesis": "Uses Z-Score to identify extreme statistical deviations and BB for price confirmation to increase trade count and hit rate.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      },
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2.0
        }
      }
    ],
    "entry": {
      "condition": "zscore_20 < -1.5 AND close < bb_lower_20",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 48
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}