{
  "dsl_version": "0.1",
  "strategy": {
    "name": "RSI_EMA_TrendFilter_Reversion",
    "type": "hybrid",
    "hypothesis": "Buying oversold RSI dips only when the price remains above a long-term EMA to ensure we are trading mean reversion within a macro uptrend.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 100
        }
      }
    ],
    "entry": {
      "condition": "rsi_14 < 30 AND close > ema_100",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 3.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 48
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}