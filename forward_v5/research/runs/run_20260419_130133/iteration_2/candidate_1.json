{
  "dsl_version": "0.1",
  "strategy": {
    "name": "ZScore_BB_MeanReversion_Aggressive",
    "type": "mean_reversion",
    "hypothesis": "Extreme price deviations measured by ZScore combined with BB lower band breaches indicate high-probability reversal points on 1h timeframe.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ZSCORE",
        "params": {
          "period": 50
        }
      },
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2.0
        }
      }
    ],
    "entry": {
      "condition": "zscore_50 < -2.0 AND close < bb_lower_20",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.5,
      "stop_loss_pct": 2.0,
      "trailing_stop_pct": null,
      "max_hold_bars": 36
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": []
  }
}