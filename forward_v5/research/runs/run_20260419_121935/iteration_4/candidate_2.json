{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Mean_Reversion_ZScore_Oscillator",
    "type": "mean_reversion",
    "hypothesis": "Price deviations beyond 2 standard deviations from the mean on 1h timeframe tend to revert, especially in high-liquidity assets like ETH.",
    "assets": [
      "ETHUSDT",
      "BTCUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      },
      {
        "name": "ATR",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "ZSCORE(20) < -2.0",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.0,
      "stop_loss_pct": 1.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 2.5
        }
      }
    ]
  }
}