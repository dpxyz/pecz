{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Crypto_Trend_Momentum_Follower",
    "type": "trend_following",
    "hypothesis": "Strong momentum trends in BTC and SOL are often sustained when price stays above a medium-term EMA and RSI shows strength without being overbought.",
    "assets": [
      "BTCUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      },
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "close > EMA(50) AND RSI(14) > 55 AND RSI(14) < 70",
      "max_per_day": 2
    },
    "exit": {
      "take_profit_pct": 4.0,
      "stop_loss_pct": 2.5,
      "trailing_stop_pct": 1.0,
      "max_hold_bars": 120
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volume",
        "params": {
          "min_volume_multiplier": 1.2
        }
      }
    ]
  }
}