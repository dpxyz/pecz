{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Mean_Reversion_ZScore_BB",
    "type": "mean_reversion",
    "hypothesis": "Ausnutzung von kurzfristigen \u00dcbertreibungen au\u00dferhalb der Bollinger B\u00e4nder unterst\u00fctzt durch statistische Z-Score Abweichungen.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2.0
        }
      },
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      },
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      }
    ],
    "entry": {
      "condition": "close < BB_low AND ZSCORE < -2.0 AND RSI < 30",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.0,
      "stop_loss_pct": 2.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.5
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 2.5
        }
      }
    ]
  }
}