{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Mean_Reversion_ZScore_Bollinger",
    "type": "mean_reversion",
    "hypothesis": "Statistische \u00dcbertreibungen vom Mittelwert (Z-Score) in Verbindung mit Bollinger Band Ausbr\u00fcchen signalisieren kurzfristige Umkehrpunkte.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "ZSCORE",
        "params": {
          "period": 20
        }
      },
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2.0
        }
      }
    ],
    "entry": {
      "condition": "ZSCORE(20) < -2.0 AND close < BB_lower",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 1.2,
      "stop_loss_pct": 1.0,
      "trailing_stop_pct": null,
      "max_hold_bars": 24
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 2.5
        }
      }
    ]
  }
}