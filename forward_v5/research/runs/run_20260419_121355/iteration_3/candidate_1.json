{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Trend_Following_EMA_Cross",
    "type": "trend_following",
    "hypothesis": "Momentum-Effekte in Krypto-Assets f\u00fchren oft zu l\u00e4ngeren Trends, die durch EMA-Crosses auf 1h-Basis effizient erfasst werden.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "EMA",
        "params": {
          "period": 20
        }
      },
      {
        "name": "EMA",
        "params": {
          "period": 50
        }
      }
    ],
    "entry": {
      "condition": "EMA(20) crosses above EMA(50) and close > EMA(50)",
      "max_per_day": 1
    },
    "exit": {
      "take_profit_pct": 4.0,
      "stop_loss_pct": 2.5,
      "trailing_stop_pct": 1.0,
      "max_hold_bars": 168
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volume",
        "params": {
          "min_volume_ma_ratio": 1.2
        }
      }
    ]
  }
}