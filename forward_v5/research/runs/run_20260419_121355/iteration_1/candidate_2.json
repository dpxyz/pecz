{
  "dsl_version": "0.1",
  "strategy": {
    "name": "Mean_Reversion_RSI_BB",
    "type": "mean_reversion",
    "hypothesis": "Ausnutzung von kurzfristigen \u00dcberverk\u00e4ufen in einem Aufw\u00e4rtstrend durch Kombination von Bollinger B\u00e4ndern und RSI.",
    "assets": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "timeframe": "1h",
    "indicators": [
      {
        "name": "RSI",
        "params": {
          "period": 14
        }
      },
      {
        "name": "BB",
        "params": {
          "period": 20,
          "std_dev": 2
        }
      },
      {
        "name": "SMA",
        "params": {
          "period": 200
        }
      }
    ],
    "entry": {
      "condition": "close < BB_lower AND RSI < 30 AND close > SMA(200)",
      "max_per_day": 3
    },
    "exit": {
      "take_profit_pct": 2.0,
      "stop_loss_pct": 2.5,
      "trailing_stop_pct": null,
      "max_hold_bars": 36
    },
    "position_sizing": {
      "method": "fixed_frac",
      "risk_per_trade_pct": 1.0
    },
    "filters": [
      {
        "type": "volatility",
        "params": {
          "max_atr_multiplier": 2.5
        }
      }
    ]
  }
}